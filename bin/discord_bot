#!/usr/bin/env ruby
require_relative "../config/environment"
require "discordrb"

bot = Discordrb::Bot.new(
  token: ENV.fetch("DISCORD_TOKEN"),
  intents: [:direct_messages]
)

bot.register_application_command(:activate, "Activate ConnectionsBot")

bot.message(private: true) do |event|
  next if event.user.bot_account?

  discord_id = event.user.id.to_s
  user = User.find_by(discord_id:)

  unless user
    event.respond("ConnectionsBot needs to be activated from a server")
    next
  end

  event.channel.start_typing
  user.handle_message(event.content)
end

bot.application_command(:activate) do |event|
  discord_id = event.user.id.to_s
  discord_username = event.user.username
  guild_id = event.server_id&.to_s

  user = User.find_or_create_by!(discord_id:) do |user|
    user.discord_username = discord_username
    user.email = "#{discord_id}@example.com"
    user.password = SecureRandom.hex
    user.active_guild_id = guild_id
  end

  pm = event.user.pm("ConnectionsBot activated! Say Hello to get started!")

  user.update!(active_guild_id: guild_id, channel_id: pm.channel.id.to_s)

  event.respond(content: "You activated ConnectionsBot! I sent you a PM", ephemeral: true)
end

bot.run
